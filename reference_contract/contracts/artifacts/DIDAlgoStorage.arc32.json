                },
                "desc": "\nAllocate boxes to begin data upload process"
            },
            {
                "name": "upload",
                "args": [
                    {
                        "type": "address",
                        "name": "pubKey",
                        "desc": "The pubkey of the DID"
                    },
                    {
                        "type": "uint64",
