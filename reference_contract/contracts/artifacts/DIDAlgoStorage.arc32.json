    "contract": {
        "name": "DIDAlgoStorage",
        "methods": [
            {
                "name": "startUpload",
                "args": [
                    {
                        "type": "address",
                        "name": "pubKey",
                        "desc": "The pubkey of the DID"
                    },
                    {
                        "type": "uint64",
                        "name": "numBoxes",
                        "desc": "The number of boxes that the data will take up"
                    },
                    {
                        "type": "uint64",
                        "name": "endBoxSize",
                        "desc": "The size of the last box"
                    },
