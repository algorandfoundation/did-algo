                        "desc": "The index of the box to upload the given chunk of data to"
                    },
                    {
                        "type": "uint64",
                        "name": "offset",
                        "desc": "The offset within the box to start writing the data"
                    },
                    {
                        "type": "byte[]",
                        "name": "data",
                        "desc": "The data to write"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "\nUpload data to a specific offset in a box"
            },
            {
                "name": "finishUpload",
                "args": [
                    {
                        "type": "address",
                        "name": "pubKey",
                        "desc": "The address of the DID"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "\nMark uploading as false"
            },
            {
                "name": "startDelete",
                "args": [
                    {
                        "type": "address",
                        "name": "pubKey",
                        "desc": "The address of the DID"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
